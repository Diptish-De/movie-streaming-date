{
    "manifest_version": 3,
    "name": "Watch Party - JioHotstar",
    "version": "1.0.0",
    "description": "Watch JioHotstar together with friends! Synced playback, live chat, emoji reactions & voice chat.",
    "permissions": [
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "*://*.hotstar.com/*",
        "*://*.jiohotstar.com/*"
    ],
    "background": {
        "service_worker": "background/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.hotstar.com/*",
                "*://*.jiohotstar.com/*"
            ],
            "js": [
                "lib/socket.io.min.js",
                "content/content.js",
                "content/overlay.js"
            ],
            "css": [
                "styles/overlay.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}